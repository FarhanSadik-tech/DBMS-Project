// ৩. ডাটা হ্যান্ডলিং (নতুন পেশেন্ট যোগ)
if(isset($_POST['add_patient'])){
    $name = $conn->real_escape_string($_POST['name']);
    $phone = $conn->real_escape_string($_POST['phone']);
    $conn->query("INSERT INTO Patients (name, phone) VALUES ('$name','$phone')");
}

// ৪. বেড অ্যাসাইন (সাথে বেড স্ট্যাটাস আপডেট)
if(isset($_POST['assign_bed'])){
    $patient = (int)$_POST['patient_id'];
    $bed = (int)$_POST['bed_id'];
    // চেক করা হচ্ছে বেডটি ফাঁকা আছে কিনা
    $check = $conn->query("SELECT status FROM Beds WHERE bed_id=$bed AND status='Available'");
    if($check->num_rows > 0){
        $conn->query("INSERT INTO Bed_Allocations (patient_id, bed_id) VALUES ($patient,$bed)");
        $conn->query("UPDATE Beds SET status='Occupied' WHERE bed_id=$bed");
    } else {
        echo "<script>alert('বেডটি আগে থেকেই বুক করা!');</script>";
    }
}

// ৫. ডিসচার্জ (বেড আবার ফাঁকা হবে)
if(isset($_POST['discharge'])){
    $alloc = (int)$_POST['allocation_id'];
    $bed_res = $conn->query("SELECT bed_id FROM Bed_Allocations WHERE allocation_id=$alloc");
    $bed_data = $bed_res->fetch_assoc();
    $bed_id = $bed_data['bed_id'];

    $conn->query("UPDATE Bed_Allocations SET discharge_date = NOW() WHERE allocation_id = $alloc");
    $conn->query("UPDATE Beds SET status='Available' WHERE bed_id = $bed_id");
}

// ড্যাশবোর্ড ডেটা ফেচিং
$totalPatients = $conn->query("SELECT COUNT(*) as c FROM Patients")->fetch_assoc()['c'];
$availableBeds = $conn->query("SELECT COUNT(*) as c FROM Beds WHERE status='Available'")->fetch_assoc()['c'];

$patients = $conn->query("SELECT * FROM Patients ORDER BY patient_id DESC LIMIT 5");
$beds = $conn->query("SELECT * FROM Beds");
$activeAlloc = $conn->query("SELECT ba.allocation_id, p.name, b.bed_number, ba.admission_date 
                             FROM Bed_Allocations ba 
                             JOIN Patients p ON ba.patient_id = p.patient_id 
                             JOIN Beds b ON ba.bed_id = b.bed_id 
                             WHERE ba.discharge_date IS NULL");
?>

