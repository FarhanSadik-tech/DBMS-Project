CREATE DATABASE IF NOT EXISTS smart_hospital_system;
USE smart_hospital_system;

-- ইউজার টেবিল
CREATE TABLE IF NOT EXISTS Users (id INT PRIMARY KEY AUTO_INCREMENT, username VARCHAR(50), password VARCHAR(50));
INSERT INTO Users (username, password) VALUES ('admin', '1234');

-- ডাক্তার টেবিল
CREATE TABLE IF NOT EXISTS Doctors (doctor_id INT PRIMARY KEY AUTO_INCREMENT, name VARCHAR(100), specialty VARCHAR(100), phone VARCHAR(20));

-- পেশেন্ট টেবিল (ডাক্তার কলামসহ)
CREATE TABLE IF NOT EXISTS Patients (patient_id INT PRIMARY KEY AUTO_INCREMENT, name VARCHAR(100), phone VARCHAR(20), assigned_doctor_id INT DEFAULT NULL);

-- বেড টেবিল
CREATE TABLE IF NOT EXISTS Beds (bed_id INT PRIMARY KEY AUTO_INCREMENT, bed_number VARCHAR(10), bed_type VARCHAR(50), status ENUM('Available', 'Occupied') DEFAULT 'Available');
INSERT INTO Beds (bed_number, bed_type, status) VALUES ('101', 'General', 'Available'), ('102', 'ICU', 'Available'), ('103', 'Cabin', 'Available');

-- বেড অ্যালকোহল টেবিল
CREATE TABLE IF NOT EXISTS Bed_Allocations (allocation_id INT PRIMARY KEY AUTO_INCREMENT, patient_id INT, bed_id INT, admission_date DATETIME DEFAULT CURRENT_TIMESTAMP, discharge_date DATETIME NULL);
